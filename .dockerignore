# Dependencies — reinstalled from the lockfile inside the image
node_modules
.pnp
.pnp.*
.yarn/*

# Build output — regenerated by `next build` in the image
.next
out
build

# Version control & CI
.git
.gitignore
.github

# Env files — never bake secrets into the image; NEXT_PUBLIC_* is passed as a build ARG
.env
.env.*

# Docker
Dockerfile
.dockerignore

# Editor / OS / logs
.vscode
.idea
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Misc dev-only files
.vercel
*.tsbuildinfo
next-env.d.ts
README.md
